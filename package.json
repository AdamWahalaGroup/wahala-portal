{
  "name": "wahala-portal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy && npm run deploy:demo:worker",
    "deploy:cron": "wrangler deploy -c cron/wrangler.jsonc",
    "cron:dev": "wrangler dev -c cron/wrangler.jsonc --test-scheduled",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply wahala-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply wahala-db --remote",
    "db:seed:local": "wrangler d1 execute wahala-db --local --file=drizzle/seed.sql",
    "db:seed:remote": "wrangler d1 execute wahala-db --remote --file=drizzle/seed.sql",
    "deploy:demo:worker": "wrangler deploy -c wrangler.demo.jsonc",
    "db:migrate:demo": "wrangler d1 migrations apply wahala-demo-db --remote -c wrangler.demo.jsonc",
    "db:seed:demo": "wrangler d1 execute wahala-demo-db --remote --file=drizzle/seed.sql -c wrangler.demo.jsonc"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.3.0",
    "arctic": "^3.7.0",
    "drizzle-orm": "0.45.2",
    "next": "^15.3.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^22.13.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.19",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.10.0"
  }
}
