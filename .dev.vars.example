# Local Cloudflare Workers vars/secrets (read by wrangler / OpenNext dev).
# Copy to `.dev.vars` and fill in. NEVER commit `.dev.vars`.
# Auth needs NO secrets — magic links use the native EMAIL binding; sessions live in KV.
# In production set secrets with: npx wrangler secret put NAME

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Auth (dev only)
# DEV_AUTH=true surfaces the magic link in the /api/auth/request response so you can
# log in locally before the email domain is onboarded. NEVER set this in production.
DEV_AUTH=true
# From-address for login emails once the domain is onboarded to Email Sending.
EMAIL_FROM=login@wahala-services.com
# Quote total (cents) above which a Wahala admin must co-sign quotes.
ADMIN_APPROVAL_THRESHOLD_CENTS=500000

# Google SSO (OAuth) — from Google Cloud Console (Web application client).
# Client id can be a var; set the SECRET in prod via `wrangler secret put GOOGLE_CLIENT_SECRET`.
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
