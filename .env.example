# SECRET values go in `.dev.vars` (see .dev.vars.example) so the Cloudflare
# Workers runtime can read them. This file documents what the app needs.

# AWS Cognito (authentication) — create a User Pool + App Client + Hosted UI domain
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=wahala.auth.us-east-1.amazoncognito.com

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Anthropic (Phase 2; route via Cloudflare AI Gateway)
ANTHROPIC_API_KEY=sk-ant-xxx
