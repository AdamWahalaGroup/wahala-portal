# Copy public (NEXT_PUBLIC_*) values into `.env.local` for `next dev`.
# Put SECRET values into `.dev.vars` (see .dev.vars.example) so the Cloudflare
# Workers runtime can read them locally.

# Clerk — https://dashboard.clerk.com (enable Organizations)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Anthropic (Phase 2; route via Cloudflare AI Gateway)
ANTHROPIC_API_KEY=sk-ant-xxx
